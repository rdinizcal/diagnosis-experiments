{
 "input": {
  "requirement_file": "replication/evaluation_inputs/effectiveness/AT1/AT1_AT001.py",
  "traces_file": "replication/analysis/data/tracesAT.csv",
  "output_dir": "outputs/cc_batch/exp1_AT1"
 },
 "ga": {
  "population_size": 50,
  "generations": 100,
  "crossover_rate": 0.95,
  "mutation_rate": 0.9,
  "target_sats": 1000,
  "stopping": {
   "mode": "cv_pr",
   "pr_threshold": 0.95,
   "check_every_generations": 1,
   "patience": 2,
   "min_samples": 50,
   "max_samples": 2000
  }
 },
 "mutation": {
  "max_mutations": 1,
  "enable_numeric_perturbation": true,
  "enable_relop_flip": false,
  "enable_logical_flip": false,
  "enable_quantifier_flip": false,
  "allowed_positions": [
   11
  ],
  "allowed_changes": {
   "11": {
    "numeric": [
     100.0,
     140.0
    ]
   }
  }
 },
 "evaluation": {
  "trace_check_timeout_sec": 3600,
  "cache_enabled": true,
  "engine": "worker",
  "parallel_workers": 1
 },
 "heuristics": {
  "interval_inference": {
   "enabled": false,
   "mode": "label",
   "empirical_validation_k": 2
  },
  "two_tier_timeout": {
   "enabled": true,
   "low_sec": 60,
   "high_sec": 600,
   "escalation": "once_per_formula"
  },
  "adaptive_range": {
   "enabled": false,
   "exploration_fraction": 0.3,
   "endpoint_init": true,
   "on_one_class": "continue",
   "widen_factor": 1.5,
   "max_widenings": 4
  },
  "time_quantization": {
   "enabled": true,
   "validate_every_n_hits": 50
  }
 }
}
